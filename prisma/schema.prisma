generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js models (Prisma adapter)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Visibility {
  PUBLIC
  PRIVATE
}

/// High-level listing category for search (vacation vs wedding / events)
enum TripKind {
  VACATION
  WEDDING_EVENT
}

enum EventType {
  FLIGHT
  HOTEL
  ACTIVITY
  MEAL
  CUSTOM
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]

  itineraries Itinerary[]
  votes       Vote[]
  comments    Comment[]
  commentVotes CommentVote[]
  starred     ItineraryStar[]

  createdAt DateTime @default(now())
}

model Itinerary {
  id            String      @id @default(cuid())
  ownerId       String
  owner         User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title         String
  slug          String      @unique
  summary       String?
  coverImageUrl String?
  visibility    Visibility  @default(PUBLIC)
  tripKind      TripKind    @default(VACATION)

  forkedFromId String?
  forkedFrom   Itinerary?  @relation("ItineraryForks", fields: [forkedFromId], references: [id], onDelete: SetNull)
  forks        Itinerary[] @relation("ItineraryForks")
  forkedAt     DateTime?

  /// Original planner display name captured at clone time ("Cloned from …")
  cloneSourceAuthorName String?

  voteScore Int   @default(0)
  hotScore  Float @default(0)

  /// Paid clone (Stripe Connect — wire in production)
  premiumCloneEnabled     Boolean @default(false)
  premiumClonePriceCents  Int?
  premiumCloneCurrency    String? @default("USD")

  tags     ItineraryTag[]
  days     Day[]
  votes    Vote[]
  comments Comment[]
  stars    ItineraryStar[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visibility, hotScore(sort: Desc)])
  @@index([visibility, tripKind, hotScore(sort: Desc)])
  @@index([ownerId])
}

model Tag {
  id    String         @id @default(cuid())
  name  String         @unique
  items ItineraryTag[]
}

model ItineraryTag {
  itineraryId String
  tagId       String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itineraryId, tagId])
}

model Day {
  id          String    @id @default(cuid())
  itineraryId String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  dayIndex    Int
  label       String?
  date        DateTime?
  events      Event[]

  @@unique([itineraryId, dayIndex])
  @@index([itineraryId])
}

model Event {
  id          String    @id @default(cuid())
  dayId       String
  day         Day       @relation(fields: [dayId], references: [id], onDelete: Cascade)
  eventIndex  Int
  type        EventType
  title       String
  description String?
  location    String?
  lat         Float?
  lng         Float?
  startsAt    DateTime?
  endsAt      DateTime?

  /// 1–5 stars, optional — planner’s rating for this stop
  ratingStars Int?

  /// Flight-specific (optional when type is FLIGHT)
  airline               String?
  departureAirportCode  String?
  arrivalAirportCode    String?
  departureAirportName  String?
  arrivalAirportName    String?

  coverImageUrl String?
  media         EventMedia[]

  /// Google Place ID (Places API) — opens correct Maps listing
  googlePlaceId String?
  /// Canonical Maps URL from Place Details (`url` field) — most reliable for "Open in Maps"
  googleMapsUrl String?
  /// Business website from Place Details when available
  websiteUrl    String?

  /// Estimated cost in minor units (e.g. cents), optional
  estimatedCostMinor Int?
  currency           String? @default("USD")

  guestPhotos GuestEventPhoto[]

  @@unique([dayId, eventIndex])
  @@index([dayId])
}

model EventMedia {
  id        String @id @default(cuid())
  eventId   String
  event     Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url       String
  width     Int?
  height    Int?
  sortOrder Int    @default(0)
}

/// Guest-uploaded memories for an event (wedding / shared trips)
model GuestEventPhoto {
  id         String   @id @default(cuid())
  eventId    String
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url        String
  caption    String?
  authorName String?
  createdAt  DateTime @default(now())

  @@index([eventId, createdAt])
}

model Vote {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itineraryId String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  value       Int

  @@unique([userId, itineraryId])
}

/// User bookmark / “star” on an itinerary (separate from upvotes)
model ItineraryStar {
  userId      String
  itineraryId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@id([userId, itineraryId])
  @@index([userId])
  @@index([itineraryId])
}

model Comment {
  id          String    @id @default(cuid())
  itineraryId String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  authorId    String
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Comment?  @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("CommentThread")
  body        String
  /// Itinerary day indices (0-based) this comment calls out, e.g. lunch on Day 3 → [2]
  mentionedDayIndices Int[] @default([])
  voteScore   Int       @default(0)
  votes       CommentVote[]
  createdAt   DateTime  @default(now())

  @@index([itineraryId, createdAt])
  @@index([itineraryId, voteScore])
}

model CommentVote {
  userId    String
  commentId String
  value     Int // 1 up, -1 down
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, commentId])
  @@index([commentId])
}
